# Copy to .env and fill in. Only OPENAI_API_KEY is required.
OPENAI_API_KEY=

# Telegram delivery. Leave empty for dry-run mode: the post is rendered and
# saved to POST_PREVIEW_PATH, plug the real channel in later.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
POST_PREVIEW_PATH=telegram_post_preview.html

# Optional overrides (defaults shown)
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
DAYS_BACK=1
TOP_N=5
MAX_REVISIONS=2
MIN_ITEMS=5
AUDIENCE=backend Python engineer
DIGEST_LANGUAGE=Ukrainian
JUDGE_THRESHOLD=4.0

# Semantic dedupe of cross-outlet duplicates
SEMANTIC_DEDUPE=1
SEMANTIC_THRESHOLD=0.86

# Cross-run memory: do not repeat stories delivered in previous digests
MEMORY_ENABLED=1
MEMORY_DIR=.trend_scout_memory
MEMORY_THRESHOLD=0.88

# Override the feed list without touching code, JSON object {"Name": "url"}
# RSS_FEEDS_JSON={"Hacker News": "https://hnrss.org/frontpage"}
